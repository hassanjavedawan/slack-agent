{
	"name": "@openviktor/db",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio",
		"db:push": "prisma db push",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@prisma/client": "^6.5.0"
	},
	"devDependencies": {
		"prisma": "^6.5.0",
		"vitest": "^3.0.0",
		"typescript": "^5.8.0"
	}
}
